    "database": {
      "dialect": "postgres",
      "entities": [
        {
          "name": "customers",
          "label": "Customers",
          "description": "Primary customer directory for the generated app.",
          "primaryKey": "id",
          "fields": [
            {
              "name": "name",
              "label": "Name",
              "type": "string",
              "required": true,
              "optional": false,
              "placeholder": "Ada Lovelace",
              "options": []
            },
            {
              "name": "email",
              "label": "Email",
              "type": "email",
              "required": true,
              "optional": false,
              "placeholder": "ada@company.com",
              "options": []
            },
            {
              "name": "segment",
              "label": "Segment",
              "type": "enum",
              "required": false,
              "optional": false,
              "defaultValue": "starter",
              "placeholder": "",
              "options": [
                "enterprise",
                "growth",
                "starter"
              ]
            },
            {
              "name": "score",
              "label": "Score",
              "type": "number",
              "required": false,
              "optional": false,
              "defaultValue": 72,
              "placeholder": "",
              "options": []
            },
            {
              "name": "notes",
              "label": "Notes",
              "type": "textarea",
              "required": false,
              "optional": true,
              "placeholder": "Context and handoff notes",
              "options": []
            }
          ]
        },
        {
          "name": "orders",
          "label": "Orders",
          "description": "Transactions that power the dashboard and table views.",
          "primaryKey": "id",
          "fields": [
            {
              "name": "title",
              "label": "Title",
              "type": "string",
              "required": true,
              "optional": false,
              "placeholder": "Order #2001",
              "options": []
            },
            {
              "name": "customername",
              "label": "Customer",
              "type": "string",
              "required": true,
              "optional": false,
              "placeholder": "Ada Lovelace",
              "options": []
            },
            {
              "name": "amount",
              "label": "Amount",
              "type": "number",
              "required": true,
              "optional": false,
              "defaultValue": 0,
              "placeholder": "",
              "options": []
            },
            {
              "name": "status",
              "label": "Status",
              "type": "enum",
              "required": false,
              "optional": false,
              "defaultValue": "draft",
              "placeholder": "",
              "options": [
                "draft",
                "paid",
                "shipped",
                "complete"
              ]
            },
            {
              "name": "shippedat",
              "label": "Shipped At",
              "type": "date",
              "required": false,
              "optional": true,
              "placeholder": "",
              "options": []
            }
          ]
        }
      ]
    },
